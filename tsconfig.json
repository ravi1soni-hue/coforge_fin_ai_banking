{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": [
    "*.ts",
    "migrations/**/*.ts",
    "node_modules"
  ],
  "include": [
    "src/**/*"
  ]
}
